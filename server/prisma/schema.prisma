generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Diagram {
  id              String           @id
  name            String
  databaseType    String
  databaseEdition String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  areas           Area[]
  customTypes     DBCustomType[]
  dependencies    DBDependency[]
  relationships   DBRelationship[]
  tables          DBTable[]
  filter          DiagramFilter?
  notes           Note[]
}

model DBTable {
  id                 String   @id
  diagramId          String
  name               String
  schema             String?
  x                  Float
  y                  Float
  fields             String
  indexes            String
  checkConstraints   String?
  color              String
  isView             Boolean  @default(false)
  isMaterializedView Boolean? @default(false)
  createdAt          Float
  width              Float?
  comments           String?
  order              Int?
  expanded           Boolean? @default(true)
  parentAreaId       String?
  diagram            Diagram  @relation(fields: [diagramId], references: [id], onDelete: Cascade)
}

model DBRelationship {
  id                String  @id
  diagramId         String
  name              String
  sourceSchema      String?
  sourceTableId     String
  targetSchema      String?
  targetTableId     String
  sourceFieldId     String
  targetFieldId     String
  sourceCardinality String
  targetCardinality String
  createdAt         Float
  diagram           Diagram @relation(fields: [diagramId], references: [id], onDelete: Cascade)
}

model DBDependency {
  id               String  @id
  diagramId        String
  schema           String?
  tableId          String
  dependentSchema  String?
  dependentTableId String
  createdAt        Float
  diagram          Diagram @relation(fields: [diagramId], references: [id], onDelete: Cascade)
}

model Area {
  id        String  @id
  diagramId String
  name      String
  x         Float
  y         Float
  width     Float
  height    Float
  color     String
  order     Int?
  diagram   Diagram @relation(fields: [diagramId], references: [id], onDelete: Cascade)
}

model DBCustomType {
  id        String  @id
  diagramId String
  schema    String?
  name      String
  kind      String
  values    String?
  fields    String?
  order     Int?
  diagram   Diagram @relation(fields: [diagramId], references: [id], onDelete: Cascade)
}

model Note {
  id        String  @id
  diagramId String
  content   String
  x         Float
  y         Float
  width     Float
  height    Float
  color     String
  order     Int?
  diagram   Diagram @relation(fields: [diagramId], references: [id], onDelete: Cascade)
}

model ChartDBConfig {
  id               Int     @id @default(autoincrement())
  defaultDiagramId String
  exportActions    String?
}

model DiagramFilter {
  diagramId String  @id
  schemaIds String?
  tableIds  String?
  diagram   Diagram @relation(fields: [diagramId], references: [id], onDelete: Cascade)
}
